# ========================================
# BACKEND ENVIRONMENT CONFIGURATION
# FastAPI + Supabase + AWS S3
# ========================================

# Application Settings
APP_NAME="SquadZero API"
DEBUG=false
ENVIRONMENT=development
API_VERSION=v1
BACKEND_URL=http://localhost:8000

# ========================================
# AI PROVIDER KEYS
# Set one or both depending on provider usage.
# - OPENROUTER_API_KEY for OpenRouter (typically starts with sk-or-v1-)
# - OPENAI_API_KEY for direct OpenAI fallback
# ========================================
OPENROUTER_API_KEY=your-openrouter-key
OPENAI_API_KEY=your-openai-key

# ========================================
# SUPABASE (PostgreSQL + Auth)
# Get these from: https://supabase.com/project/settings/api
# ========================================
SUPABASE_URL=https://iatjbhvtcvnsbitpbfim.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImlhdGpiaHZ0Y3Zuc2JpdHBiZmltIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzQ3MTM0MjksImV4cCI6MjA5MDI4OTQyOX0.-zJPUHIHfVWhN3YLZpxaZW5H9-RbtYE2LdHKK0QWGkk
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImlhdGpiaHZ0Y3Zuc2JpdHBiZmltIiwicm9sZSI6InNlcnZpY2Vfcm9sZSIsImlhdCI6MTc3NDcxMzQyOSwiZXhwIjoyMDkwMjg5NDI5fQ.hzWCNMTF5u3aJQqv6wFDfhpthTk3b4Q5wYPt9-Z1Hxo

# ========================================
# JWT & SESSION SECURITY
# Generate SECRET_KEY with: python -c "import secrets; print(secrets.token_urlsafe(32))"
# ========================================
SECRET_KEY=q235074869w306487234081248049
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ========================================
# COOKIE CONFIGURATION
# Dev: COOKIE_SECURE=false | Prod: COOKIE_SECURE=true
# ========================================
COOKIE_NAME=session
COOKIE_SECURE=false
COOKIE_HTTPONLY=true
COOKIE_SAMESITE=lax
COOKIE_DOMAIN=

# ========================================
# CORS & FRONTEND ACCESS
# Comma-separated list of allowed origins
# ========================================
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:8000
ALLOW_CREDENTIALS=true

# ========================================
# ADMIN ACCESS CONTROL
# User with this email gets admin privileges
# ========================================
ADMIN_EMAIL=admin@university.com

# ========================================
# AWS S3 FILE STORAGE
# Get these from: https://console.aws.amazon.com/iam/
# Instructions: Create IAM user with S3 access, generate access/secret keys
# ========================================
AWS_S3_BUCKET=your-bucket-name
AWS_ACCESS_KEY_ID=AKIA1234567890ABCDEF
AWS_SECRET_ACCESS_KEY=your-secret-access-key-here
AWS_REGION=us-east-1

# ========================================
# PASSWORD RESET
# Token expiry time in minutes
# ========================================
PASSWORD_RESET_TOKEN_EXPIRE_MINUTES=60
