# ========================================
# BACKEND CONFIGURATION (FastAPI + Supabase)
# ========================================

# Application
APP_NAME="SquadZero API"
DEBUG=false
ENVIRONMENT=development

# Supabase Configuration (https://supabase.com)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# JWT and Session
SECRET_KEY=your-secret-key-generate-with-python-secrets
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Cookie Configuration
COOKIE_NAME=session
COOKIE_SECURE=true
COOKIE_HTTPONLY=true
COOKIE_SAMESITE=lax
COOKIE_DOMAIN=

# CORS Configuration
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
ALLOW_CREDENTIALS=true

# Admin Configuration
ADMIN_EMAIL=admin@university.com

# AWS S3 Configuration
AWS_S3_BUCKET=your-bucket-name
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_REGION=us-east-1

# Password Reset
PASSWORD_RESET_TOKEN_EXPIRE_MINUTES=60

# ========================================
# FRONTEND CONFIGURATION (React + Vite)
# ========================================

# Frontend API Base URL
VITE_API_BASE_URL=http://localhost:8000
VITE_APP_NAME="SquadZero"
